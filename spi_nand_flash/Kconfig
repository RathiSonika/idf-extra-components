menu "SPI NAND Flash configuration"

    config NAND_FLASH_VERIFY_WRITE
        bool "Verify SPI NAND flash writes"
        default n
        help
            If this option is enabled, any time SPI NAND flash is written then the data will be read
            back and verified. This can catch hardware problems with SPI NAND flash, or flash which
            was not erased before verification.

    config NAND_FLASH_ENABLE_BDL
        bool "Enable Block Device Layer (BDL) support"
        depends on IDF_INIT_VERSION >= "6.0"
        default n
        help
            Enable Block Device Layer (BDL) support for SPI NAND Flash. This provides:
            - Standard esp_blockdev_t interface for layered architecture
            - Flash Block Device Layer (raw NAND flash access)
            - Wear-Leveling Block Device Layer (logical sector access with wear leveling)
            - Advanced layered API (spi_nand_flash_init_with_layers)
            When disabled, only the legacy API is available.
            When enabled, the legacy spi_nand_flash_init_device() is not available (returns
            ESP_ERR_NOT_SUPPORTED). Use spi_nand_flash_init_with_layers().

            Note: This option requires ESP-IDF >= 6.0 (esp_blockdev component).
            Enabling this on ESP-IDF < 6.0 will result in a build error.

    config NAND_ENABLE_STATS
        bool "Host test statistics enabled"
        depends on IDF_TARGET_LINUX
        default n
        help
            This option enables gathering host test statistics and SPI NAND flash wear levelling simulation.

    config NAND_FLASH_ANONYMOUS_DETECT
        bool "Enable anonymous SPI NAND chip detection"
        depends on !IDF_TARGET_LINUX
        default n
        help
            When enabled, chip init tries the vendor database first, then falls back to
            ONFI parameter page read and optional manual geometry (see dependent options).
            When disabled, init behavior matches a database-only build (smaller binary).

    config NAND_FLASH_ANONYMOUS_MANUAL
        bool "Enable manual geometry fallback for unknown chips"
        depends on NAND_FLASH_ANONYMOUS_DETECT
        default n
        help
            When enabled together with anonymous detection, user-supplied page geometry
            and timing values from Kconfig are used if database and ONFI paths fail.
            All values must match the attached part datasheet. Defaults are invalid until
            you set each field from the datasheet (init returns ESP_ERR_INVALID_ARG).

    if NAND_FLASH_ANONYMOUS_MANUAL

        config NAND_FLASH_ANONYMOUS_MANUAL_PAGE_SIZE
            int "Manual: page size in bytes"
            default 0
            range 0 8192
            help
                Data bytes per page from the chip datasheet. Must be a power of two
                (e.g. 2048, 4096). Default 0 is rejected at init until configured.

        config NAND_FLASH_ANONYMOUS_MANUAL_PAGES_PER_BLOCK
            int "Manual: pages per block"
            default 0
            range 0 256
            help
                Pages per block from the datasheet. Must be a power of two (e.g. 64).
                Default 0 is rejected at init until configured.

        config NAND_FLASH_ANONYMOUS_MANUAL_NUM_BLOCKS
            int "Manual: number of blocks"
            default 0
            range 0 65536
            help
                Total block count from the datasheet. Default 0 is rejected at init.

        config NAND_FLASH_ANONYMOUS_MANUAL_NUM_PLANES
            int "Manual: number of planes"
            default 1
            range 1 4
            help
                Plane count from the datasheet (1 or 2 for typical SPI NAND). Values
                greater than 1 enable read/program plane-select column addressing.

        config NAND_FLASH_ANONYMOUS_MANUAL_T_R_US
            int "Manual: page read time (us)"
            default 0
            range 0 100000
            help
                Maximum typical page read time in microseconds (t_R).

        config NAND_FLASH_ANONYMOUS_MANUAL_T_PROG_US
            int "Manual: page program time (us)"
            default 0
            range 0 100000
            help
                Maximum typical page program time in microseconds (t_PROG).

        config NAND_FLASH_ANONYMOUS_MANUAL_T_BERS_US
            int "Manual: block erase time (us)"
            default 0
            range 0 1000000
            help
                Maximum typical block erase time in microseconds (t_BERS).

    endif

endmenu
